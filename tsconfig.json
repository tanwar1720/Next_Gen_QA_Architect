{
  "compilerOptions": {
    "target": "es2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "types": ["node", "@playwright/test"],
    "baseUrl": ".",
    "paths": {
      "@api/*": ["src/api/*"],
      "@bdd/*": ["src/bdd/*"],
      "@config/*": ["src/config/*"],
      "@fixtures/*": ["src/fixtures/*"],
      "@pages/*": ["src/pages/*"],
      "@web-pages/*": ["src/pages/web/*"],
      "@mobile-pages/*": ["src/pages/mobile-web/*"],
      "@utils/*": ["src/utils/*"]
    }
  },
  "include": ["playwright.config.ts", "src/**/*.ts", "tests/**/*.ts"]
}
